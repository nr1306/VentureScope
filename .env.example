# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Web Search
TAVILY_API_KEY=your_tavily_api_key_here

# Observability
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Database (overridden in docker-compose for containerized runs)
DATABASE_URL=postgresql+asyncpg://venturesscope:venturesscope@localhost:5432/venturesscope

# Redis (overridden in docker-compose for containerized runs)
REDIS_URL=redis://localhost:6379/0

# Embeddings — Ollama local (run: ollama pull nomic-embed-text)
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_LANGFUSE_HOST=https://cloud.langfuse.com
